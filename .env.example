# --- Backend (см. backend/config.py, docs/adr/adr-002-backend-http-orm.md) ---
# Обязательно: async SQLAlchemy + asyncpg. Заполните своё подключение:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Отдельная БД для pytest backend/tests: если задано, имеет приоритет над DATABASE_URL (см. backend/tests/conftest.py, docs/tests.md)
# TEST_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/test_db

# Bind uvicorn (backend/main.py)
API_HOST=127.0.0.1
API_PORT=8000
# Общий секрет для bot → backend (Authorization: Bearer …). Контракт: docs/api/backend-v1.openapi.yaml
INTERNAL_API_TOKEN=

LOG_LEVEL=INFO

# LLM через OpenRouter (только backend /v1/dialog-messages)
OPENROUTER_API_KEY=
# По умолчанию в коде: https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.7
# Лимит сообщений в контексте диалога на сервере (по умолчанию в коде: 30)
MAX_HISTORY_MESSAGES=

# Системный промпт потока хранится в БД (Flow.system_prompt); бот его не задаёт.
# LLM_MAX_TOKENS=

# --- Bot (HTTP-клиент к backend; без прямого OpenRouter) ---
# Базовый URL backend без завершающего слэша (совпадает с http://API_HOST:API_PORT)
BACKEND_BASE_URL=http://127.0.0.1:8000
BOT_TOKEN=
# UUID потока из таблицы flows — тот же flow_id, что в POST /v1/dialog-messages
FLOW_ID=
